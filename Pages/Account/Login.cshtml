@page
@model DotNetIdentityDeepDive.Pages.Account.LoginModel
@{
}

<div class="container border p-4">
    <form method="post">
        <div class="text-danger" asp-validation-summary="ModelOnly"></div>
        <div class="form-group row mb-4">
            <div class="col-sm-3">
                <label asp-for="Credential.UserName" ></label>
            </div>
            <div class="col-sm-5">
                <input type="text" asp-for="Credential.UserName" class="form-control" />
            </div>
            <span class="text-danger" asp-validation-for="Credential.UserName"></span>
            <div></div>
            <div class="col-sm-3">
                <label asp-for="Credential.Password" ></label>
            </div>
            <div class="col-sm-5">
                <input type="text" asp-for="Credential.Password" class="form-control" />
            </div>
            <span class="text-danger" asp-validation-for="Credential.Password"></span>
        </div>

        <div class="row">
            <div class="col-sm-12">
                <button type="submit" class="btn btn-primary">Login</button>
            </div>
        </div>
    </form>
</div>